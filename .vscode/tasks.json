{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev: Serve",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/serve.ps1"
      ],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "close": false
      }
    },
    {
      "label": "Dev: Open Preview",
      "dependsOn": ["Dev: Serve"],
      "type": "shell",
      "command": "Start-Process",
      "args": [
        "vscode://vscode.simple-browser/show?url=http://127.0.0.1:5501/index.html"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
